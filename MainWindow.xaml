<Window x:Class="GitLFSUnlocker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Git LFS Lock Manager"
        Height="620" Width="900"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3">

    <Window.Resources>
        <!-- Button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BFBFBF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EBF3FB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#BFBFBF"/>
                                <Setter Property="BorderBrush" Value="#BFBFBF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid row style -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#CCE4F7"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF3FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🔒" FontSize="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <StackPanel>
                <TextBlock Text="Git LFS Lock Manager" FontSize="20" FontWeight="SemiBold" Foreground="#1A1A1A"/>
                <TextBlock Text="View and unlock your Git LFS file locks" FontSize="12" Foreground="#666"/>
            </StackPanel>
        </StackPanel>

        <!-- Repository path selector -->
        <Border Grid.Row="1" Background="White" CornerRadius="6"
                BorderBrush="#DDD" BorderThickness="1" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Repository:" VerticalAlignment="Center"
                           FontSize="13" Foreground="#444" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" x:Name="RepoPathTextBox"
                         FontSize="13" VerticalContentAlignment="Center"
                         Padding="8,6" BorderBrush="#CCC" BorderThickness="1"
                         Background="#FAFAFA"
                         IsReadOnly="True"/>
                <Button Grid.Column="2" Content="Browse…" Margin="8,0,0,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="BrowseButton_Click"/>
                <Button Grid.Column="3" Content="↻ Refresh" Margin="8,0,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Click="RefreshButton_Click"
                        x:Name="RefreshButton"
                        IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- Filter / selection controls -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- User filter -->
            <TextBlock Grid.Column="0" Text="Filter by user:" FontSize="12" Foreground="#555"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1" x:Name="UserFilterComboBox"
                      FontSize="12" Padding="8,5"
                      IsEnabled="False"
                      SelectionChanged="UserFilterComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Lock count -->
            <TextBlock Grid.Column="2" x:Name="LockCountLabel" Text="No locks loaded"
                       FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="12,0,0,0"/>

            <Button Grid.Column="3" Content="Select All" Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButton}"
                    Click="SelectAllButton_Click"
                    x:Name="SelectAllButton" IsEnabled="False"
                    Padding="10,5" FontSize="12"/>
            <Button Grid.Column="4" Content="Deselect All"
                    Style="{StaticResource SecondaryButton}"
                    Click="DeselectAllButton_Click"
                    x:Name="DeselectAllButton" IsEnabled="False"
                    Padding="10,5" FontSize="12"/>
        </Grid>

        <!-- Main data grid -->
        <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                Background="White" ClipToBounds="True">
            <Grid>
                <DataGrid x:Name="LocksDataGrid"
                          AutoGenerateColumns="False"
                          SelectionMode="Extended"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EFEFEF"
                          BorderThickness="0"
                          RowHeight="38"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#FAFAFA"
                          SelectionUnit="FullRow">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F7F7F7"/>
                            <Setter Property="Foreground" Value="#555"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <!-- Checkbox column -->
                        <DataGridTemplateColumn Width="50" CanUserResize="False" CanUserSort="False">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox x:Name="HeaderCheckBox"
                                              HorizontalAlignment="Center"
                                              IsThreeState="True"
                                              Click="HeaderCheckBox_Click"
                                              Tag="HeaderCheckBox"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Click="RowCheckBox_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- File path column -->
                        <DataGridTextColumn Header="File Path"
                                            Binding="{Binding FilePath}"
                                            Width="*"
                                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="ToolTip" Value="{Binding FilePath}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Locked By column -->
                        <DataGridTextColumn Header="Locked By"
                                            Binding="{Binding LockedBy}"
                                            Width="160"
                                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#555"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Lock ID column -->
                        <DataGridTextColumn Header="Lock ID"
                                            Binding="{Binding LockId}"
                                            Width="100"
                                            IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#888"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state overlay -->
                <StackPanel x:Name="EmptyStatePanel"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="📂" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock x:Name="EmptyStateMessage" Text="Select a repository to view LFS locks"
                               FontSize="14" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4" Margin="0,8,0,0" Padding="10,6"
                Background="#EBF3FB" CornerRadius="4"
                x:Name="StatusBorder" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusIcon" Text="ℹ️" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusLabel" Text="" FontSize="12" VerticalAlignment="Center" Foreground="#0078D4"/>
            </StackPanel>
        </Border>

        <!-- Bottom action bar -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SelectedCountLabel" Grid.Column="0"
                       Text="" FontSize="12" Foreground="#555"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="UnlockButton"
                    Content="🔓  Unlock Selected"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="False"
                    Click="UnlockButton_Click"
                    Padding="18,9" FontSize="14"/>
        </Grid>
    </Grid>
</Window>
